# ─── WhatsApp / n8n ────────────────────────────────────────────────────────────
# URL del webhook n8n que procesa los mensajes.
# También configurable via UI → pestaña Webhook (sin redeploy).
N8N_WEBHOOK_URL=https://tu-n8n.dominio.com/webhook/TU_WEBHOOK_ID

# ─── Triage Agent HITL (opcional) ─────────────────────────────────────────────
# URL de Ollama para el agente de triage.
# Si no se define → triage usa solo keywords (sin LLM call).
# En Docker Swarm/Easypanel mismo servidor: http://172.17.0.1:11434
# Para desactivar triage LLM: dejar sin definir.
# OLLAMA_BASE_URL=http://172.17.0.1:11434

# Modelo Ollama para triage (debe estar descargado: ollama pull qwen2.5:7b)
# TRIAGE_MODEL=qwen2.5:7b

# ─── OpenRouter (opcional) ─────────────────────────────────────────────────────
# Solo necesario si se usa openrouterClient directamente.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Easypanel: volumen persistente ────────────────────────────────────────────
# OBLIGATORIO: montar volumen en /app/data
# Contiene: messages.db (SQLite — historial + config), auth/ (sesión Baileys)
# Sin volumen: se pierde sesión WA y datos en cada redeploy.
